# =========================
# CONFIGURAÇÕES TELEGRAM
# =========================
# Crie um bot com o @BotFather e cole o token abaixo.
TELEGRAM_BOT_TOKEN=

# Envie uma mensagem para o seu bot e use getUpdates para descobrir o chat_id.
TELEGRAM_CHAT_ID=

# =========================
# TERMOS E HISTÓRICO
# =========================
TERMOS_ARQUIVO=termos.txt
ESTADO_ARQUIVO=estado.json
DOWNLOADS_DIR=downloads

# =========================
# FREQUÊNCIA DE BUSCA
# =========================
# Intervalo entre verificações completas.
INTERVALO_MINUTOS=15

# Variação aleatória adicional, em segundos, para não ficar consultando sempre no mesmo segundo.
INTERVALO_VARIACAO_SEGUNDOS=60

# Quantos dias para trás o robô deve tentar achar edições.
# Para verificar apenas hoje e os últimos 2 dias, deixe 2.
DIAS_RETROATIVOS=2

# Quantos dias para frente o robô deve testar.
# Para verificar apenas publicações já existentes, deixe 0.
DIAS_FUTUROS=0

# Timeout de requisições em segundos.
TIMEOUT_REQUISICAO=40

# =========================
# AVISOS
# =========================
# true = avisa quando qualquer nova edição for encontrada e analisada.
AVISAR_NOVA_EDICAO=true

# true = avisa mesmo quando não encontrou nenhum termo.
# Se ficar false, ele ainda registra no histórico; se AVISAR_NOVA_EDICAO=true, enviará resumo simples.
AVISAR_SEM_TERMOS=false

# true = envia mensagem periódica dizendo que o robô está ativo.
ENVIAR_HEARTBEAT=true
HEARTBEAT_HORAS=6

# true = salva os PDFs baixados na pasta downloads.
BAIXAR_PDFS=true

# true = toca alerta sonoro no Windows quando encontrar termo.
TOCAR_SOM=true

# false = não reprocessa PDFs já registrados no estado.json.
# Mude para true somente para testes.
REPROCESSAR_JA_LIDOS=false

# Quantos trechos mostrar por termo encontrado.
LIMITE_TRECHOS_POR_TERMO=3
